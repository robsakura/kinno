# Database (Railway auto-injects DATABASE_URL when PostgreSQL plugin is added)
DATABASE_URL="postgresql://user:password@host:5432/kinno"

# NextAuth
NEXTAUTH_URL="http://localhost:3000"
NEXTAUTH_SECRET=""   # Generate with: openssl rand -base64 32

# Google OAuth (https://console.cloud.google.com)
GOOGLE_CLIENT_ID=""
GOOGLE_CLIENT_SECRET=""

# TMDb API (https://developer.themoviedb.org — free)
TMDB_API_KEY=""
TMDB_READ_ACCESS_TOKEN=""   # Bearer token (preferred)

# OMDb API (https://www.omdbapi.com — free tier: 1000 req/day)
OMDB_API_KEY=""

# Public
NEXT_PUBLIC_TMDB_IMAGE_BASE="https://image.tmdb.org/t/p"
